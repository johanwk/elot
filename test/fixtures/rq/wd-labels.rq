# SPARQL fixture for Step 1.3 test-parse-rq-from-cache.
# The test never executes this query; it only verifies that the parser
# uses the pre-baked cache (see rq-cache/ sibling directory) when the
# cache is newer than both the .rq file and its data source.

PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?id ?label WHERE {
  ?id rdfs:label ?label .
}
LIMIT 10
