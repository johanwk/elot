# Local RDF fixture for Step 1.3 / 1.3.1 tests.
#
# Used by:
#   - test-parse-rq-from-cache              (mtime only; content irrelevant)
#   - test-parse-ttl-with-robot-local       (ROBOT queries this directly)
#   - test-parse-rq-with-robot-fresh-cache  (ROBOT queries this via .rq)
#   - test-parse-rq-stale-cache-reingests   (ROBOT queries this via .rq)
#
# Keep stable; tests assert exact labels and definitions.

@prefix ex:   <http://example.org/ex/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ex:Widget
    rdfs:label      "Widget" ;
    skos:definition "A generic widget used for testing." .

ex:Gadget
    rdfs:label      "Gadget" ;
    skos:definition "A gadget, subclass of widget." .

ex:connectsTo
    rdfs:label      "connectsTo" ;
    skos:definition "Relates one widget to another." .
