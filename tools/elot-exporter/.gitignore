# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Emacs backup files (ending in ~)
*~

# Emacs auto-save files (surrounded by #)
#*#

# Lock files (created for buffers)
.#*

# Also ignore Org-mode backup files (if you use them)
*.org~

# Additional temporary files
*.elc
.aider*
DELETED
