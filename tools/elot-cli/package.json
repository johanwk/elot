{
  "name": "elot",
  "displayName": "Elot: Org-mode Ontology Editor",
  "version": "0.3.5",
  "publisher": "johanwk",
  "description": "Manchester Syntax generation for ontologies written in Org-mode",
  "icon": "images/elot-icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "ontology",
    "OWL",
    "Manchester Syntax",
    "Org-mode",
    "RDF",
    "knowledge graph"
  ],
  "badges": [],
  "qna": "marketplace",
  "repository": {
    "type": "git",
    "url": "https://github.com/johanwk/elot"
  },
  "license": "GPL-3.0-or-later",
  "main": "./dist/extension.js",
  "categories": [
    "Programming Languages",
    "Data Science"
  ],
  "bin": {
    "elot": "./dist/cli.js"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "elot.tangle",
        "title": "Elot: Tangle to Manchester Syntax"
      },
      {
        "command": "elot.toggleLabels",
        "title": "Elot: Toggle Label Display",
        "icon": "$(tag)"
      },
      {
        "command": "elot.toggleOrgIndent",
        "title": "Elot: Toggle Org Indent Mode",
        "icon": "$(indent)"
      },
      {
        "command": "elot.importOwl",
        "title": "Elot: Import OWL Ontology",
        "icon": "$(cloud-download)"
      },
      {
        "command": "elot.downloadExporter",
        "title": "Elot: Download/Update elot-exporter"
      },
      {
        "command": "elot.exportHtml",
        "title": "Elot: Export to HTML"
      }
    ],
    "keybindings": [
      {
        "command": "elot.toggleLabels",
        "key": "f5",
        "when": "resourceExtname == .org"
      },
      {
        "command": "editor.toggleFold",
        "key": "tab",
        "when": "editorTextFocus && resourceExtname == .org && !editorHasSelection && !inSnippetMode && !suggestWidgetVisible && !editorTabMovesFocus"
      },
      {
        "command": "editor.unfoldAll",
        "key": "shift+tab",
        "when": "editorTextFocus && resourceExtname == .org && !editorHasSelection && !inSnippetMode && !suggestWidgetVisible"
      },
      {
        "command": "elot.toggleOrgIndent",
        "key": "ctrl+shift+i",
        "when": "editorTextFocus && resourceExtname == .org"
      }
    ],
    "configuration": {
      "title": "ELOT",
      "properties": {
        "elot.labelDisplay.fontStyle": {
          "type": "string",
          "default": "italic",
          "enum": ["italic", "normal", "oblique"],
          "description": "Font style for displayed labels (when label display is ON)"
        },
        "elot.labelDisplay.hoverEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show hover information (label, type, annotations) for CURIEs in Org files"
        },
        "elot.javaPath": {
          "type": "string",
          "default": "java",
          "description": "Path to the Java executable (Java 21+ required for elot-exporter)"
        },
        "elot.lint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ELOT ontology lint checks (structural, CURIE validation, keyword appropriateness)"
        },
        "elot.pandocPath": {
          "type": "string",
          "default": "pandoc",
          "description": "Path to the Pandoc executable (auto-downloaded if not found; required for HTML export)"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "elot.toggleLabels",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.toggleOrgIndent",
          "when": "resourceExtname == .org",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "elot.tangle",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.toggleLabels",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.toggleOrgIndent",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.importOwl",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.exportHtml",
          "when": "resourceExtname == .org",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "build:wasm": "cd elot-orgize && wasm-pack build --target nodejs --out-dir ../src/wasm",
    "build:parser": "npx peggy --format commonjs ../../syntax/owl-manchester.peggy -o src/omnParser.js --allowed-start-rules ClassExpression,ClassExpressionList,ObjectPropertyExpressionList,SubPropertyChain,DataRange,Fact,IndividualIRIList",
    "bundle": "npm run build:wasm && npm run build:parser && node esbuild.mjs",
    "build": "tsc",
    "compile": "tsc",
    "watch": "tsc -w",
    "test": "tsx src/tests/golden.test.ts",
    "test:syntax": "tsx src/tests/omnSyntaxCheck.test.ts",
    "test:html": "tsx src/tests/exportHtml.test.ts",
    "test:html-post": "tsx src/tests/exportHtmlPostprocess.test.ts",
    "test:html-integration": "tsx src/tests/exportHtmlIntegration.test.ts",
    "test:html-all": "npm run test:html && npm run test:html-post && npm run test:html-integration",
    "test:db-lang": "tsx src/tests/db/langPicker.test.ts",
    "test:db-read": "tsx src/tests/db/elotDb.test.ts",
    "test:db": "npm run test:db-lang && npm run test:db-read",
    "elot": "tsx src/cli.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.75.0",
    "peggy": "^4.2.0",
    "tsx": "^4.0.0",
    "esbuild": "^0.25.0"
  }
}
