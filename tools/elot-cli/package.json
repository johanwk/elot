{
  "name": "elot",
  "displayName": "Elot: Org-mode Ontology Editor",
  "version": "0.3.5",
  "publisher": "johanwk",
  "description": "Manchester Syntax generation for ontologies written in Org-mode",
  "icon": "images/elot-icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "ontology",
    "OWL",
    "Manchester Syntax",
    "Org-mode",
    "RDF",
    "knowledge graph"
  ],
  "badges": [],
  "qna": "marketplace",
  "repository": {
    "type": "git",
    "url": "https://github.com/johanwk/elot"
  },
  "license": "GPL-3.0-or-later",
  "main": "./dist/extension.js",
  "categories": [
    "Programming Languages",
    "Data Science"
  ],
  "bin": {
    "elot": "./dist/cli.js"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "elot.tangle",
        "title": "Elot: Tangle to Manchester Syntax"
      },
      {
        "command": "elot.toggleLabels",
        "title": "Elot: Toggle Label Display",
        "icon": "$(tag)"
      },
      {
        "command": "elot.toggleOrgIndent",
        "title": "Elot: Toggle Org Indent Mode",
        "icon": "$(indent)"
      },
      {
        "command": "elot.importOwl",
        "title": "Elot: Import OWL Ontology",
        "icon": "$(cloud-download)"
      },
      {
        "command": "elot.downloadExporter",
        "title": "Elot: Download/Update elot-exporter"
      },
      {
        "command": "elot.exportHtml",
        "title": "Elot: Export to HTML"
      },
      {
        "command": "elot.dbInfo",
        "title": "Elot: Label DB Info"
      },
      {
        "command": "elot.toggleGlobalLabels",
        "title": "Elot: Toggle Global Label Display",
        "icon": "$(tag)"
      },
      {
        "command": "elot.activateSource",
        "title": "Elot: Activate Label Source"
      },
      {
        "command": "elot.deactivateSource",
        "title": "Elot: Deactivate Label Source"
      },
      {
        "command": "elot.reorderActiveSources",
        "title": "Elot: Reorder Active Label Sources"
      },
      {
        "command": "elot.registerSource",
        "title": "Elot: Register Label Source"
      },
      {
        "command": "elot.refreshSource",
        "title": "Elot: Refresh Label Source"
      }
    ],
    "keybindings": [
      {
        "command": "elot.toggleLabels",
        "key": "f5",
        "when": "resourceExtname == .org"
      },
      {
        "command": "elot.toggleGlobalLabels",
        "key": "f5",
        "when": "editorTextFocus && resourceExtname != .org"
      },
      {
        "command": "editor.toggleFold",
        "key": "tab",
        "when": "editorTextFocus && resourceExtname == .org && !editorHasSelection && !inSnippetMode && !suggestWidgetVisible && !editorTabMovesFocus"
      },
      {
        "command": "editor.unfoldAll",
        "key": "shift+tab",
        "when": "editorTextFocus && resourceExtname == .org && !editorHasSelection && !inSnippetMode && !suggestWidgetVisible"
      },
      {
        "command": "elot.toggleOrgIndent",
        "key": "ctrl+shift+i",
        "when": "editorTextFocus && resourceExtname == .org"
      }
    ],
    "configuration": {
      "title": "ELOT",
      "properties": {
        "elot.labelDisplay.fontStyle": {
          "type": "string",
          "default": "italic",
          "enum": ["italic", "normal", "oblique"],
          "description": "Font style for displayed labels (when label display is ON)"
        },
        "elot.labelDisplay.hoverEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show hover information (label, type, annotations) for CURIEs in Org files"
        },
        "elot.javaPath": {
          "type": "string",
          "default": "java",
          "description": "Path to the Java executable (Java 21+ required for elot-exporter)"
        },
        "elot.lint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ELOT ontology lint checks (structural, CURIE validation, keyword appropriateness)"
        },
        "elot.pandocPath": {
          "type": "string",
          "default": "pandoc",
          "description": "Path to the Pandoc executable (auto-downloaded if not found; required for HTML export)"
        },
        "elot.dbPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ELOT label SQLite database (written by `elot-cli db ...`). Empty = use VS Code globalStorage location. Workspace-level overrides user-level."
        },
        "elot.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the elot-cli executable used by `Elot: Register/Refresh Label Source`. Empty = look up `elot-cli` on PATH."
        },
        "elot.activeLabelSources": {
          "type": "array",
          "default": [],
          "description": "Ordered list of active label sources. Each entry is either a string (source name) or `{\"source\": \"name\", \"dataSource\": \"path\"}`. First match wins on lookup conflicts.",
          "items": {
            "type": ["string", "object"]
          }
        },
        "elot.preferredLanguages": {
          "type": "array",
          "default": [],
          "description": "Preferred language tags (BCP-47) for label resolution, in priority order. Empty = use [untagged, en] default.",
          "items": {
            "type": "string"
          }
        },
        "elot.globalLabelDisplay.hoverEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show DB-backed hover (label, type, definition, provenance) for CURIEs and IRIs in non-Org files."
        },
        "elot.globalLabelDisplay.maxIds": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "description": "Maximum number of CURIE/IRI tokens to decorate per file. When the cap is reached the status bar shows a 'capped' warning."
        },
        "elot.globalLabelDisplay.includeLanguages": {
          "type": "array",
          "default": [],
          "description": "Language IDs in which DB-backed hover/decorations apply. Empty = use built-in default (plaintext, markdown, typescript, javascript, python, json, yaml, xml, turtle, sparql, ...). Org is always excluded.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "elot.toggleLabels",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.toggleOrgIndent",
          "when": "resourceExtname == .org",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "elot.tangle",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.toggleLabels",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.toggleOrgIndent",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.importOwl",
          "when": "resourceExtname == .org",
          "group": "navigation"
        },
        {
          "command": "elot.exportHtml",
          "when": "resourceExtname == .org",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "build:wasm": "cd elot-orgize && wasm-pack build --target nodejs --out-dir ../src/wasm",
    "build:parser": "npx peggy --format commonjs ../../syntax/owl-manchester.peggy -o src/omnParser.js --allowed-start-rules ClassExpression,ClassExpressionList,ObjectPropertyExpressionList,SubPropertyChain,DataRange,Fact,IndividualIRIList",
    "bundle": "npm run build:wasm && npm run build:parser && node esbuild.mjs",
    "build": "tsc",
    "compile": "tsc",
    "watch": "tsc -w",
    "test": "tsx src/tests/golden.test.ts",
    "test:syntax": "tsx src/tests/omnSyntaxCheck.test.ts",
    "test:html": "tsx src/tests/exportHtml.test.ts",
    "test:html-post": "tsx src/tests/exportHtmlPostprocess.test.ts",
    "test:html-integration": "tsx src/tests/exportHtmlIntegration.test.ts",
    "test:html-all": "npm run test:html && npm run test:html-post && npm run test:html-integration",
    "test:db-lang": "tsx src/tests/db/langPicker.test.ts",
    "test:db-read": "tsx src/tests/db/elotDb.test.ts",
    "test:db-write": "tsx src/tests/db/elotDbWrite.test.ts",
    "test:db-paths": "tsx src/tests/db/dbPaths.test.ts",
    "test:db-parsers": "tsx src/tests/db/parsers.test.ts",
    "test:db-prefixes": "tsx src/tests/db/prefixes.test.ts",
    "test:db-rq-cache": "tsx src/tests/db/rqCache.test.ts",
    "test:db-ttl-robot": "tsx src/tests/db/ttlRobot.test.ts",
    "test:db-roundtrip": "tsx src/tests/db/registerRoundtrip.test.ts",
    "test:db-org": "tsx src/tests/db/orgParser.test.ts",
    "test:db-cli-e2e": "tsx src/tests/db/cliE2e.test.ts",
    "test:db-golden": "tsx src/tests/db/golden.test.ts",
    "test:db-bridge": "tsx src/tests/db/bridge.test.ts",
    "test:db-hover-token": "tsx src/tests/db/dbHoverToken.test.ts",
    "test:db-hover-render": "tsx src/tests/db/dbHoverRender.test.ts",
    "test:db-decorations-scan": "tsx src/tests/db/dbDecorationsScan.test.ts",
    "test:db-decorations": "npm run test:db-decorations-scan",
    "test:settings-active-sources": "tsx src/tests/settings/activeSources.test.ts",
    "test:settings-reorder": "tsx src/tests/settings/reorder.test.ts",
    "test:settings-cli-runner": "tsx src/tests/settings/cliRunner.test.ts",
    "test:db-resolve": "tsx src/tests/db/dbResolve.test.ts",
    "test:db": "npm run test:db-lang && npm run test:db-read && npm run test:db-write && npm run test:db-paths && npm run test:db-parsers && npm run test:db-prefixes && npm run test:db-rq-cache && npm run test:db-ttl-robot && npm run test:db-roundtrip && npm run test:db-org && npm run test:db-cli-e2e && npm run test:db-golden && npm run test:db-bridge && npm run test:db-hover-token && npm run test:db-hover-render && npm run test:db-decorations && npm run test:db-resolve && npm run test:settings",
    "test:settings": "npm run test:settings-active-sources && npm run test:settings-reorder && npm run test:settings-cli-runner",
    "compile:test": "tsc -p tsconfig.test.json",
    "prepare:electron-fixtures": "tsx src/tests/electron/prepareFixtures.ts",
    "pretest:electron": "npm run bundle && npm run compile:test && npm run prepare:electron-fixtures",
    "test:electron": "node ./dist-test/runTests.js",
    "elot": "tsx src/cli.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.5.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.0",
    "glob": "^10.3.10",
    "mocha": "^10.7.0",
    "peggy": "^4.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
